# ============================================================
#  LEONEX MDM TENDER PLATFORM — .gitignore
#  Production-ready: protects secrets, caches, and temp files
# ============================================================

# ── Credentials & Secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl

# ── Virtual Environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
.npm/
*.lock
package-lock.json

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── OS Generated ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & Temp Files ────────────────────────────────────────
*.log
logs/
browser_logs.txt
error.txt
td_inputs.txt
td_results_source.html

# ── Data & Output Files ─────────────────────────────────────
data/
*.xlsx
*.csv
*.json.bak

# ── Test & Debug Scripts ─────────────────────────────────────
test_*.py
*.test.py
backend/check_db.py

# ── Docker ───────────────────────────────────────────────────
# docker-compose.override.yml

# ── Gemini / AI ──────────────────────────────────────────────
.gemini/
.sixth/
