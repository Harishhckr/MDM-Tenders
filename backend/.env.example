# ============================================
# Tender Intelligence Platform — .env.example
# Copy this file to .env and fill in values
# NEVER commit the real .env file!
# ============================================

APP_NAME="Tender Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY="your-secret-key-here"

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL — Render DB
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV (Windows PC): Use EXTERNAL URL — your PC cannot reach internal URL
DATABASE_URL=postgresql://mdm_db_tp32_user:MX8J4VpCJb5fjsZRCU6JH1GLtAuzctqz@dpg-d7isi8faqgkc73a4jgr0-a.oregon-postgres.render.com/mdm_db_tp32?sslmode=require

# RENDER SERVER: Set this in Render Dashboard → Environment → DATABASE_URL
# DATABASE_URL=postgresql://mdm_db_tp32_user:MX8J4VpCJb5fjsZRCU6JH1GLtAuzctqz@dpg-d7isi8faqgkc73a4jgr0-a/mdm_db_tp32?sslmode=require

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Scraping
# ─────────────────────────────────────────────────────────────────────────────
# HEADLESS_MODE=False → Chrome opens as VISIBLE tab on local Windows PC
# HEADLESS_MODE=True  → Silent (set this on Render / Linux servers)
HEADLESS_MODE=False
MAX_PAGES=10
MAX_CONCURRENT_TABS=3
SCRAPE_TIMEOUT=30
RESET_SCRATCH_PAD=True

# Filesystem
DATA_DIR=data
LOGS_DIR=logs

# CORS — must match the frontend server origin
CORS_ORIGINS=http://127.0.0.1:8080,https://harishhckr.github.io