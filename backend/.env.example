# ============================================
# Tender Intelligence Platform — .env.example
# Copy this file to .env and fill in values
# NEVER commit the real .env file!
# ============================================

APP_NAME="Tender Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY="your-secret-key-here"

# PostgreSQL
DATABASE_URL=postgresql://user:password@dpg-xxx-a/dbname?sslmode=require

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Scraping
HEADLESS_MODE=False
MAX_PAGES=10
MAX_CONCURRENT_TABS=3
SCRAPE_TIMEOUT=30
RESET_SCRATCH_PAD=True

# Filesystem
DATA_DIR=data
LOGS_DIR=logs

# CORS — must match the frontend server origin
CORS_ORIGINS=http://127.0.0.1:8080,https://harishhckr.github.io