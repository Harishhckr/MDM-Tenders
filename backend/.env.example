# ============================================================
# MDM Tender Platform — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env!
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Tender Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY=change-me-in-production-use-random-256bit

# ── Database (PostgreSQL) ────────────────────────────────────
# Production: Set DATABASE_URL in Render dashboard env vars
# Local dev:  Use external Render URL below
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Scraping ─────────────────────────────────────────────────
HEADLESS_MODE=True
MAX_PAGES=10
MAX_CONCURRENT_TABS=3
SCRAPE_TIMEOUT=30
RESET_SCRATCH_PAD=True

# ── Filesystem ───────────────────────────────────────────────
DATA_DIR=data
LOGS_DIR=logs

# ── CORS ─────────────────────────────────────────────────────
# Frontend + Admin portal origins (comma-separated)
CORS_ORIGINS=https://harishhckr.github.io,http://127.0.0.1:8080,http://localhost:5500

# ── JWT Authentication ───────────────────────────────────────
# IMPORTANT: Change these in production!
JWT_SECRET=change-this-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Service URLs (for reference) ─────────────────────────────
# Frontend:      https://harishhckr.github.io/MDM-Tenders/
# Admin Portal:  https://harishhckr.github.io/MDM-Tenders/admin/
# Backend API:   https://mdm-tenders.onrender.com
# Local API:     http://localhost:8000