# ============================================
# Tender Intelligence Platform — .env
# ============================================

APP_NAME="Tender Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY="leonex-tender-secret-2026"

# PostgreSQL — change user/password/dbname as needed
DATABASE_URL=postgresql://postgres:password@localhost:5432/tenderdb

# Redis — default local
REDIS_URL=redis://localhost:6379/0

# Scraping
HEADLESS_MODE=False
MAX_PAGES=10
MAX_CONCURRENT_TABS=3
SCRAPE_TIMEOUT=30
RESET_SCRATCH_PAD=True

# Filesystem
DATA_DIR=data
LOGS_DIR=logs

# CORS — must match the frontend server origin
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
